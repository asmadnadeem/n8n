    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.ai_response;\nconst cleaned = raw.replace(/```json|```/g, '').trim();\nconst parsed = JSON.parse(cleaned);\nreturn [{\n  json: {\n    ...$input.first().json,\n    lead_score: parsed.lead_score,\n    project_complexity: parsed.project_complexity,\n    recommended_response: parsed.recommended_response,\n    reason: parsed.reason\n  }\n}];"
      },
