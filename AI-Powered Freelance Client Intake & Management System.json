        "jsonBody": "={\n  \"contents\": [{\n    \"parts\": [{\n      \"text\": \"You are a freelance design business assistant. Analyze this client inquiry and respond ONLY with a valid JSON object containing these exact fields: lead_score (number 1-10), project_complexity (low, medium, or high), recommended_response (professional or decline), reason (one sentence). Client details - Project Type: {{ $json.project_type }}, Budget: {{ $json.budget }}, Description: {{ $json.description }}\"\n    }]\n  }]\n}",
